{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "bundler",
    "target": "ES2019",
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node"],
  },
  "exclude": ["lib", "e2e", "node_modules", "test-workspace", "rollup.config.ts"]
}

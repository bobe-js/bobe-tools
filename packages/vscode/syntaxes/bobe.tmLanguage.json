{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "bobe",
  "scopeName": "source.bobe",
  "patterns": [
    { "include": "#comments" },
    { "include": "#control-flow" },
    { "include": "#tags" },
    { "include": "#components" },
    { "include": "#expressions" },
    { "include": "#strings" },
    { "include": "#single-quoted-string" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "match": "//.*$", "name": "comment.line.double-slash.bobe" }]
    },
    "control-flow": {
      "patterns": [
        {
          "comment": "匹配 if 后面的内容直到行尾，内部识别为 JS",
          "begin": "\\b(if|else)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.bobe" }
          },
          "end": "$",
          "patterns": [{ "include": "source.js" }]
        },
        {
          "comment": "完全修复首字母白色的 for 逻辑",
          "begin": "\\b(for)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.bobe" }
          },
          "end": "(?=$|//)",
          "patterns": [
            {
              "match": ";",
              "name": "punctuation.terminator.statement.bobe"
            },
            {
              "comment": "使用零宽断言探测非空字符，但不消耗它",
              "begin": "(?=[^;\\s])",
              "end": "(?=;|(?=$|//))",
              "patterns": [{ "include": "source.js" }]
            }
          ]
        }
      ]
    },
    "tags": {
      "patterns": [
        {
          "comment": "匹配行首或空格后的标签名",
          "begin": "(?<=^|\\s)([a-z0-9]+)(?=\\s|$|\\s+[a-zA-Z])",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.bobe" }
          },
          "end": "(?=$)",
          "patterns": [
            { "include": "#attributes" },
            { "include": "#expressions" },
            { "include": "#strings" },
            { "include": "#single-quoted-string" }
          ]
        }
      ]
    },
    "components": {
      "patterns": [
        {
          "comment": "匹配 ${js_expression} 结构的组件",
          "begin": "(\\$\\{)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.template-expression.begin.bobe" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.definition.template-expression.end.bobe" }
          },
          "patterns": [
            {
              "comment": "在花括号中间注入 JS 语法",
              "include": "source.js"
            }
          ]
        },
        {
          "comment": "紧跟在组件后的属性匹配",
          "match": "([a-zA-Z\\-0-9@]+)(=)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.bobe" },
            "2": { "name": "keyword.operator.assignment.bobe" }
          }
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "comment": "匹配 key= 结构，给 key 上色",
          "match": "([a-zA-Z\\-0-9@]+)(=)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.bobe" },
            "2": { "name": "keyword.operator.assignment.bobe" }
          }
        }
      ]
    },
    "expressions": {
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.bracket.curly.begin.bobe" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.bracket.curly.end.bobe" }
      },
      "name": "meta.embedded.block.javascript.bobe",
      "patterns": [{ "include": "source.js" }]
    },
    "strings": {
      "name": "string.quoted.double.bobe",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.bobe" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.bobe" }
      }
    },
    "single-quoted-string": {
      "name": "string.quoted.single.bobe",
      "begin": "'",
      "end": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.bobe" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.bobe" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.bobe",
          "match": "\\\\."
        }
      ]
    }
  }
}

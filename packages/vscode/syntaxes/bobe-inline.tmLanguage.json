{
  "scopeName": "inline.bobe",
  "injectionSelector": "L:source.ts, L:source.tsx, L:source.js, L:string.template.js, L:text.html.vue, L:text.html.derivative, L:source.svelte",
  "patterns": [
    {
      "name": "meta.embedded.inline.bobe",
      "contentName": "source.bobe",
      "begin": "(bobe)((?:\\s*(<)([^`]*)(>))?)(`)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.tagged-template.js" },
        "3": { "name": "punctuation.definition.typeparameters.begin.ts" },
        "4": { "name": "entity.name.type.ts" },
        "5": { "name": "punctuation.definition.typeparameters.end.ts" },
        "6": { "name": "punctuation.definition.string.template.begin.js" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.js" }
      },

{
  "name": "bobe",
  "displayName": "Bobe",
  "icon": "./icon.png",
  "description": "bobe",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "build": "echo 'success'"
  },
  "publisher": "smooth-cat",
  "contributes": {
    "typescriptServerPlugins": [
      {
        "name": "bobe-ts-service-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "languages": [
      {
        "id": "bobe",
        "aliases": [
          "bobe",
          "bobe"
        ],
        "extensions": [
          "bobe"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bobe",
        "scopeName": "source.bobe",
        "path": "./syntaxes/bobe.tmLanguage.json"
      },
      {
        "scopeName": "inline.bobe",
        "path": "./syntaxes/bobe-inline.tmLanguage.json",
        "embeddedLanguages": {
          "source.bobe": "bobe"
        },
        "injectTo": [
          "source.ts",
          "source.js",
          "source.tsx",
          "source.jsx",
          "source.svelte",
          "source.vue",
          "text.html.basic",
          "text.html.derivative",
          "text.html.vue"
        ]
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bobe-js/bobe-tools"
  },
  "homepage": "https://github.com/bobe-js/bobe-tools",
  "dependencies": {
    "bobe-ts-service-plugin": "workspace:*"
  }
}
